  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "setup": "lerna run setup",
    "build:dev": "lerna run build:dev",
    "build:prod": "lerna run build:prod",
    "build:development": "lerna run build:dev && pnpm run artifact",
    "build:production": "lerna run build:prod && pnpm run artifact",
    "build": "lerna run build",
    "start": "lerna run start",
    "site:start": "lerna run start --scope site",
    "review": "lerna run lint:check,format:check,typecheck",
    "test": "lerna run test",
    "test:coverage": "lerna run test:coverage",
    "artifact": "rm -rf build && mkdir -p build && lerna run artifact && zip -q -r build.zip build",
    "build:serve": "pnpm build && pnpm artifact && pnpm serve",
    "serve": "concurrently \"pnpm:serve:*\"",
    "serve:build": "serve -p 5501 -s -C build",
    "serve:emulator": "serve -p 5500 testing/emulator"
  },
  "devDependencies": {
